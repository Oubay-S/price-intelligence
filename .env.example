# =============================================================
# .env.example — Copier ce fichier en .env et remplir les valeurs
# IMPORTANT : Le fichier .env NE DOIT JAMAIS être commité sur Git
# =============================================================

# --------------------------
# AIRFLOW — Identifiants admin
# --------------------------
AIRFLOW_UID=50000           # UID Unix de l'utilisateur (garde 50000 sur Windows/Mac)
AIRFLOW_GID=0
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin123          # Change en production !

# --------------------------
# POSTGRES (backend Airflow)
# --------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow_secret             # Change en production !
POSTGRES_DB=airflow

# --------------------------
# NIFI — Accès interface web
# --------------------------
NIFI_USERNAME=admin
NIFI_PASSWORD=adminpassword123               # Min 12 caractères requis par NiFi

# --------------------------
# BIGTABLE EMULATOR
# --------------------------
# Cette variable indique aux clients Python/Java d'utiliser l'émulateur
# et non le vrai GCP. CRITIQUE pour ne pas payer !
BIGTABLE_EMULATOR_HOST=bigtable-emulator:8086

# Valeurs fictives (l'émulateur ne vérifie pas les vraies credentials)
GOOGLE_CLOUD_PROJECT=price-intel-local
BIGTABLE_INSTANCE_ID=price-intel-instance

# --------------------------
# GCP (utilisé UNIQUEMENT semaine 4 — déploiement final)
# --------------------------
# GCP_PROJECT_ID=ton-vrai-projet-gcp
# GCP_REGION=europe-west1
