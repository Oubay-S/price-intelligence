# =============================================================================
# PriceRadar — backend/.env.example
# =============================================================================
# Copy this file to `.env` (same directory) and fill in every "<...>"
# placeholder.  Never commit your real `.env` — it's gitignored.
#
# Two ways the values reach the running service:
#   * Local dev (host venv) — pydantic-settings reads backend/.env directly
#     via app.config.Settings (BACKEND_DIR / ".env").
#   * Docker Compose — the backend service has `env_file: ./backend/.env`
#     and overrides host-specific values (DB host, Redis host, credential
#     path) in its `environment:` block.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Google Cloud / BigQuery
# -----------------------------------------------------------------------------
# Real GCP project that owns the BigQuery dataset created by the dbt pipeline.
# `gcp-credentials.json` is a service-account JSON for that project, kept at
# the repo root (gitignored).  Inside Docker the file is mounted to
# /opt/gcp/gcp-credentials.json — compose overrides GOOGLE_APPLICATION_CREDENTIALS
# automatically; only fill in the *host* path here for local-venv runs.
GCP_PROJECT_ID=<your-gcp-project-id>
BIGQUERY_DATASET=<your-bigquery-dataset>
BIGQUERY_TABLE=<your-bigquery-products-table>
GOOGLE_APPLICATION_CREDENTIALS=<absolute-path-to-gcp-credentials.json-on-your-machine>

# Curated mart tables produced by dbt.  Defaults match the agreed naming
# in dbt/models/mart/* — override only if the analyst renames a model.
BIGQUERY_MART_PRODUCT_STATS=mart_product_stats
BIGQUERY_MART_BRAND_RANKINGS=mart_brand_rankings
BIGQUERY_MART_PRICE_DROPS=mart_price_drops
BIGQUERY_MART_TRENDING=mart_trending
BIGQUERY_MART_SITE_PRICES=mart_site_prices


# -----------------------------------------------------------------------------
# 2. Auth (JWT)
# -----------------------------------------------------------------------------
# Generate a real secret for SECRET_KEY before deploying anywhere:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-with-secrets.token_hex(32)>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# slowapi rate limits — syntax is "<count>/<period>".
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute


# -----------------------------------------------------------------------------
# 3. Stores (Postgres + Redis)
# -----------------------------------------------------------------------------
# DATABASE_URL: raw libpq URL (NOT SQLAlchemy `+psycopg2` form — the service
# uses psycopg2's ThreadedConnectionPool directly).
#   * Local venv run    → host-side: postgresql://postgres@localhost:5432/PriceIntelligence
#   * Compose (auto)    → backend service overrides to postgres-app:5432
DATABASE_URL=postgresql://<user>[:<password>]@localhost:5432/<database>

# Redis is used for hot-path BigQuery caching and WebSocket pub/sub.
#   * Local venv run    → redis://127.0.0.1:6379
#   * Compose (auto)    → redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379

# NiFi contentListener that the streaming flow POSTs to. Compose overrides
# to http://nifi:8081/contentListener.
NIFI_URL=http://localhost:8081/contentListener


# -----------------------------------------------------------------------------
# 4. /internal/* shared secret
# -----------------------------------------------------------------------------
# Used by NiFi's InvokeHTTP to authenticate against the FastAPI internal
# endpoints (price-event ingest, etc.).  Empty value = dev mode, auth
# disabled.  Generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`
# and configure the same value in the NiFi processor's X-Internal-Key header.
INTERNAL_API_KEY=


# -----------------------------------------------------------------------------
# 5. SMTP / email
# -----------------------------------------------------------------------------
# Powers verification, password-reset, and offline price-drop emails.
#
# Dev / testing — Mailtrap Sandbox (https://mailtrap.io):
#   1. Create an inbox in Mailtrap → "My Inbox".
#   2. Inside the inbox, "Show Credentials" → "SMTP Settings".
#   3. Pick the "Integrations → Generic / SMTP" option.
#   4. Paste host / port / username / password below.
#   Mailtrap captures every email in its inbox UI — nothing is actually
#   delivered, so any value of EMAIL_FROM_ADDRESS works.
#
# Prod — Resend (https://resend.com):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USERNAME=resend
#   SMTP_PASSWORD=<your-resend-api-key>
#   EMAIL_FROM_ADDRESS=no-reply@<your-verified-domain>
#   Domain must be verified in the Resend dashboard (SPF + DKIM DNS records).
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=<mailtrap-inbox-username>
SMTP_PASSWORD=<mailtrap-inbox-password>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=15

EMAIL_FROM_ADDRESS=no-reply@priceradar.local
EMAIL_FROM_NAME=PriceRadar

# Where the verification / reset email links should send the user.  Must be
# reachable by the user's browser, NOT by the backend container.
FRONTEND_URL=http://localhost:4200

# Token TTLs (in hours).
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1

# Size of the email thread pool.  SMTP is sync; 4 workers is plenty for
# dev volume.  Bump in prod if you see queue-lag in the logs.
EMAIL_THREAD_POOL_SIZE=4

# Master kill-switch — set to false in CI / unit tests where there's no
# SMTP server.  When false, every send becomes a no-op (logged at INFO).
EMAIL_ENABLED=true
